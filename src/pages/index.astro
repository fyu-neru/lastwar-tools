---
import Base from '../layouts/Base.astro';
import { t, localePath } from '../i18n/utils';
import { tools } from '../tools/registry';

const lang = 'en';
---

<Base>
  <section class="hero">
    <h1>{t(lang, 'home.hero_title')}</h1>
    <p>{t(lang, 'home.hero_subtitle')}</p>
    <a href={localePath(lang, '/tools')} class="btn-primary">
      {t(lang, 'home.browse_tools')}
    </a>
  </section>

  <section class="tools-section">
    <h2>{t(lang, 'home.all_tools')}</h2>
    {tools.length === 0 ? (
      <p class="empty">{t(lang, 'tools.no_tools')}</p>
    ) : (
      <div class="tools-grid">
        {tools.map(tool => (
          <a
            href={tool.status === 'available' ? localePath(lang, `/tools/${tool.id}`) : '#'}
            class={`tool-card ${tool.status === 'coming-soon' ? 'coming-soon' : ''}`}
          >
            <h3>{t(lang, tool.titleKey)}</h3>
            <p>{t(lang, tool.descKey)}</p>
            {tool.status === 'coming-soon' && (
              <span class="badge">{t(lang, 'home.coming_soon')}</span>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</Base>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.1rem;
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: #1a1a1a;
    color: #fff;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
  }

  .btn-primary:hover {
    background: #374151;
  }

  .tools-section {
    margin-top: 3rem;
  }

  .tools-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .empty {
    color: #9ca3af;
    font-style: italic;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .tool-card {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .tool-card:hover:not(.coming-soon) {
    border-color: #9ca3af;
  }

  .tool-card.coming-soon {
    opacity: 0.5;
    cursor: default;
  }

  .tool-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .tool-card p {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .badge {
    margin-top: 0.5rem;
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.15rem 0.4rem;
    background: #f3f4f6;
    border-radius: 4px;
    color: #6b7280;
  }
</style>
