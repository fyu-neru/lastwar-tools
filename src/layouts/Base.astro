---
import { getLang, t, localePath, switchLangPath } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLang(Astro.url);
const { title, description } = Astro.props;
const siteName = t(lang, 'site.name');
const siteDesc = t(lang, 'site.description');
const pageTitle = title ? `${title} — ${siteName}` : siteName;
const pageDesc = description ?? siteDesc;
const altLangPath = switchLangPath(Astro.url);
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-TW' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="alternate" hreflang={lang === 'en' ? 'zh-TW' : 'en'} href={altLangPath} />
  </head>
  <body>
    <nav class="navbar">
      <a href={localePath(lang, '/')} class="nav-brand">{siteName}</a>
      <div class="nav-links">
        <a href={localePath(lang, '/')}>{t(lang, 'nav.home')}</a>
        <a href={localePath(lang, '/tools')}>{t(lang, 'nav.tools')}</a>
        <a href={altLangPath} class="lang-switch">
          {lang === 'en' ? '繁中' : 'EN'}
        </a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <p>{t(lang, 'footer.rights')}</p>
    </footer>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #fff;
    color: #1a1a1a;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    background: #fff;
  }

  .nav-brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: #1a1a1a;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a {
    color: #4b5563;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .nav-links a:hover {
    color: #1a1a1a;
  }

  .lang-switch {
    padding: 0.25rem 0.6rem;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  main {
    flex: 1;
    padding: 2rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .footer {
    border-top: 1px solid #e5e7eb;
    padding: 1rem 1.5rem;
    text-align: center;
    font-size: 0.8rem;
    color: #9ca3af;
  }
</style>
